/* ================================
外部リンクの際に表示
=================================== */ 
$(function(){
	var $modal      = $('#external-link-modal');
	var $overlay    = $modal.find('.modal-overlay');
	var $content    = $modal.find('.modal-content');
	var $btnYes     = $('#external-link-yes');
	var $btnNo      = $('#external-link-no');
	var targetHref;     // 外部リンクの URL
	var lastTrigger = null; // クリック元の要素を保持
	$('a[target="_blank"], a[href^="http"]').on('click', function(e){
		var linkHost = this.hostname;
		if (linkHost && linkHost !== window.location.hostname) {
			e.preventDefault();
			targetHref = this.href;
			lastTrigger = this;
			openModal();
		}
	});
	function openModal(){
		$modal.removeAttr('hidden');
		$content.attr('tabindex', '-1').focus();
		trapFocus();
	}
	function closeModal(){
		$modal.attr('hidden', true);
		releaseFocusTrap();
		if (lastTrigger) {
			setTimeout(function(){
				lastTrigger.focus();
			}, 0);
		}
	}
	$btnYes.on('click', function(){
		window.open(targetHref, '_blank', 'noopener');
		closeModal();
	});
	$btnNo.add($overlay).on('click', closeModal);
	var focusable = $content.find('button');
	var firstF    = focusable.first();
	var lastF     = focusable.last();
	function trapFocus(){
		firstF.focus();
		$content.on('keydown.trap', function(e){
			if (e.key === 'Tab') {
				if (e.shiftKey && document.activeElement === firstF[0]) {
					e.preventDefault();
					lastF.focus();
				} else if (!e.shiftKey && document.activeElement === lastF[0]) {
					e.preventDefault();
					firstF.focus();
				}
			}
			if (e.key === 'Escape') closeModal();
		});
	}
	function releaseFocusTrap(){
		$content.off('keydown.trap');
	}
});

/* ================================
Contact Form7のアクセシビリティ
=================================== */ 
// Submit後最初の要素にフォーカスを当てる
(function () {
	function focusFirstField(form) {
		if (!form) return;
		const first = form.querySelector(
			'input:not([type="hidden"]):not([disabled]), select:not([disabled]), textarea:not([disabled]), button:not([disabled])'
		);
		if (first) {
			first.focus({ preventScroll: false });
		}
	}
	function focusMessage(form) {
		const msg = form.querySelector('.wpcf7-response-output');
		if (!msg) return;
		msg.setAttribute('tabindex', '-1');
		msg.setAttribute('role', 'status');
		msg.setAttribute('aria-live', 'polite');
		msg.focus({ preventScroll: false });
	}
	// 成功時のみ：メッセージへフォーカス
	document.addEventListener('wpcf7mailsent', function (event) {
		const form = event.target;
		setTimeout(() => focusMessage(form), 0);
	}, false);
	// エラー系：必ずフォーム先頭へフォーカス
	['wpcf7invalid', 'wpcf7mailfailed', 'wpcf7spam'].forEach((evtName) => {
		document.addEventListener(evtName, function (event) {
			const form = event.target;
			setTimeout(() => focusFirstField(form), 0);
		}, false);
	});
})();
document.addEventListener('invalid', function(e){
  if (e.target && e.target.closest && e.target.closest('form.wpcf7-form')) {
    e.preventDefault(); // ネイティブ吹き出しを止める
  }
}, true);
document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('.wpcf7-form [required]').forEach(function (el) {
    el.removeAttribute('required');
  });
});