/* Dropdown Menu */
$(function() {
	// 初期設定：すべてのドロップダウンを閉じた状態に
	$('.dropdown__btn').each(function() {
		var $btn  = $(this);
		var $menu = $('#' + $btn.data('target'));
		$btn
			.attr('aria-expanded', 'false');
		$menu
			.attr('aria-hidden', 'true')
			.prop('hidden', true);
	});
	$('.dropdown__btn').on('click', function(e) {
		e.preventDefault();
		var $btn   = $(this);
		var $menu  = $('#' + $btn.data('target'));
		var isOpen = $btn.attr('aria-expanded') === 'true';
		$('.dropdown__btn').not($btn).each(function() {
			var $otherBtn  = $(this);
			var $otherMenu = $('#' + $otherBtn.data('target'));
			$otherBtn
				.attr('aria-expanded', 'false');
			$otherMenu
				.attr('aria-hidden', 'true')
				.prop('hidden', true)
				.slideUp(200);
		});
		$btn
			.attr('aria-expanded', String(!isOpen));
		$menu
			.attr('aria-hidden', String(isOpen))
			.prop('hidden', isOpen)
			.slideToggle(200, function() {
			if (!isOpen) {
				// 開いたら最初のメニュー項目にフォーカス
				$menu.find('a[role="menuitem"]').first().focus();
			}
		});
	});
});
$(function() {
	var $toggler   = $('#header-sp-toggler');
	var $menuPanel = $('#header-sp-menu');
	$toggler.attr({
		'aria-expanded': 'false',
		'aria-controls': 'header-sp-menu',
		'aria-label': 'Open main menu'
	});
	$menuPanel
		.attr({
		'aria-hidden': 'true'
	})
		.prop('hidden', true)
		.hide();
	$toggler.on('click', function(e) {
		e.preventDefault();
		var isOpen = $toggler.attr('aria-expanded') === 'true';
		$toggler
			.attr('aria-expanded', String(!isOpen))
			.attr('aria-label', isOpen ? 'Open main menu' : 'Close main menu')
			.toggleClass('active');
		// ② メニューパネルの表示切り替え
		$menuPanel
			.attr('aria-hidden', String(isOpen))
			.prop('hidden', isOpen)
			.fadeToggle(200, function() {
			if (!isOpen) {
				$menuPanel.find('[role="menuitem"]').first().focus();
			} else {
				$toggler.focus();
			}
		});
		$menuPanel.find('.dropdown__btn').each(function() {
			var $btn  = $(this);
			var $sub  = $('#' + $btn.data('target'));
			$btn.attr('aria-expanded', 'false');
			$sub
				.attr('aria-hidden', 'true')
				.prop('hidden', true)
				.hide();
		});
	});
	$(document).on('keydown', function(e) {
		if (e.key === 'Escape' && $toggler.attr('aria-expanded') === 'true') {
			$toggler.click();
		}
	});
});


/* ================================
Footer
=================================== */ 
$(function () {
	const $footer = $('footer');              // 監視するフッター
	const $hide   = $('#header-sp-logo');  // 消したい要素
	function toggleOnFooter() {
		const winTop  = $(window).scrollTop();
		const winBtm  = winTop + $(window).height();
		const footTop = $footer.offset().top;
		if (winBtm >= footTop) {
			$hide.stop(true, true).fadeOut(200);
		} else {
			$hide.stop(true, true).fadeIn(200);
		}
	}
	$(window).on('scroll resize', toggleOnFooter);
	toggleOnFooter(); // 初回実行
});

/* ================================
Accordion
=================================== */ 
$(function () {
	$('.btn-accordion').each(function () {
		var $btn = $(this);
		var $panel = $('#' + $btn.data('target'));
		$btn.attr('aria-expanded', 'false');
		$panel.attr('aria-hidden', 'true').prop('hidden', true);
	});
	$('.btn-accordion').on('click', function () {
		var $btn = $(this);
		var $panel = $('#' + $btn.data('target'));
		var isOpen = $btn.attr('aria-expanded') === 'true';
		if (isOpen) {
			// 自分を閉じるだけ
			$btn.attr('aria-expanded', 'false').removeClass('active');
			$panel.attr('aria-hidden', 'true').slideUp(200, function () {
				$panel.prop('hidden', true);
			});
		} else {
			// まずすべて閉じる（Promiseを使って完了後に開く）
			var closePromises = [];
			$('.btn-accordion').each(function () {
				var $otherBtn = $(this);
				var $otherPanel = $('#' + $otherBtn.data('target'));
				if ($otherBtn[0] !== $btn[0]) {
					$otherBtn.attr('aria-expanded', 'false').removeClass('active');
					const p = new Promise(function (resolve) {
						$otherPanel.slideUp(200, function () {
							$otherPanel.prop('hidden', true).attr('aria-hidden', 'true');
							resolve();
						});
					});
					closePromises.push(p);
				}
			});
			// すべて閉じ終わったら、自分を開く
			Promise.all(closePromises).then(function () {
				$btn.attr('aria-expanded', 'true').addClass('active');
				$panel.prop('hidden', false).attr('aria-hidden', 'false').slideDown(200);
			});
		}
	});
});

