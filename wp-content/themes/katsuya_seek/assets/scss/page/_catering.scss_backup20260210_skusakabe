/* ================================
Catering: Common
=================================== */ 
.catering-body #error {
	text-align: center;
	ul {
		list-style: none;
		li {
			margin-bottom: 7px;
			&:last-child {margin-bottom: 0;}
			a {
				color: #dc3545 !important;
				font-weight: $bold;
			}
		}
	}
}
.catering-body {
	input,textarea,radio,select,a,button {
		&:focus {
			outline: 3px solid #1a73e8;
			outline-offset: 3px;
			border-radius: 4px;  
					
		}
	}
}
.catering-form .form-control, .catering-form .form-select {
	border: 1px solid $d-black;
	padding: 10px 15px;
	&--xs {width: 150px;}
}
.catering-form .radio-wrap {
	display: flex;
	align-items: start;
	input {
		margin-top: 6px;
    	margin-right: 10px;
		@include sm-monitor() {margin-top: 3px;}
	}
}
.catering-form .btn, .confirm-form .btn {
	background-color: $d-black;
	color: $white;
	padding: 10px 40px;
	border-radius: 0;
	width: auto;
}
.catering-form .table {
	tr {
		&.radio-row {
			th,td {vertical-align: inherit;}
		}
	}
	th,td {
		vertical-align: middle;
		border: none;
		width: 25%;
		padding: 10px 0;
		@include lg-monitor() {
			display: block;
			width: 100%;
		}
	}
	th {
		padding: 10px 15px 10px 0;
		@include lg-monitor() {
			padding-left: 0;
			padding-bottom: 10px;
		}
		&.heading {
			padding-bottom: 0 !important;
		}
	}
	td {
		padding-right: 10px;
		@include lg-monitor() {
			padding-top: 0;
			padding-right: 0;
		}
	}
	&--col1 {
		th {padding-left: 0;}
	}
}
.catering-form fieldset {padding: 0;}
.catering-form .form-col2 {
	label {
		margin-right: 20px;
		white-space: nowrap;
		width: 55px;
	}
	&__col {
		&:first-of-type {
			margin-top: 10px;
			margin-bottom: 10px;
		}
	}
	.form-select, .form-control {
		width: 250px;
		max-width: 100%;
	}
}
.confirm-form fieldset {padding: 0;}
.confirm-title {
	font-size: 30px;
	text-transform: uppercase;
	padding-bottom: 7px;
	position: relative;
	border-bottom: 2px solid $d-black;
	@include xxl-monitor() {font-size: 26px;}
	@include sm-monitor() {font-size: 22px;}
}
.confirm-form input, .confirm-form textarea {
	border: none;
	padding: 0;
	width: 100%;
	display: block;
}
.confirm-form textarea {line-height: 1.8;}
.confirm-form .wrap {
	margin-bottom: 25px;
	&:last-child {margin-bottom: 0;}
	&__title {
		font: {
			family: $primary-en;
			size: 20px;
			weight: $s-bold;
		}
		background-color: $d-black;
		color: $white;
		padding: 5px 10px;;
		@include sm-monitor() {font-size: 16px;}
	}
	&__title-sm {
		font: {
			family: $primary-en;
			size: 22px;
			weight: $s-bold;
		}
		@include xxl-monitor() {font-size: 20px;}
		@include sm-monitor() {font-size: 18px;}
	}
	&__label {
		display: block;
		padding-right: 15px;
		font-weight: $reg;
	}
	&__list {
		li {
			padding-bottom: 10px;
			&:last-child {padding-bottom: 0;}
		}
	}
}
.confirm-form .wrap2 {
	margin-bottom: 20px;
	&:last-child {margin-bottom: 0;}
	label {
		font-weight: $s-bold;
		display: block;
		margin-bottom: 5px;
	}
	input {width: 100%;}
}
.confirm-form-total {
	border-top: 1px solid $d-black;
	padding-top: 15px;
	&__label, input {
		font: {
			weight: $s-bold;
			size: 22px;
		}
		@include xxl-monitor() {font-size: 18px;}
	}
}
.confirm-form-table {
	border: none;
	caption-side: top;
	caption {
		font-weight: $bold;
		color: $white;
		background-color: $d-black;
		padding: 7px 15px;
	}
	tr:nth-child(even) {background-color: $xl-gray;}
	th,td {border: none;}
	th {
		font-weight: $s-bold;
		border-bottom: 1px solid $d-black;
	}
}

/* ================================
Catering
=================================== */ 
#catering-sc1 .wrap {
	display: block;
	text-align: center;
	color: $white;
	font-weight: $bold;
	padding: 100px 15px;
	position: relative;
	@include sm-monitor() {padding: 75px 15px;}
	&:before {
		content: '';
		width: 100%;
		height: 100%;
		position: absolute;
		left: 0;
		top: 0;
		background-color: rgba($black, .6);
	}
	span {
		display: block;
		position: relative;
		z-index: 1;
		color: $white;
		font-weight: $bold;
		font-size: 36px;
		@include xxl-monitor() {font-size: 26px;}
		@include sm-monitor() {font-size: 22px;}
		&.sm {
			font: {
				weight: $reg;
				size: 26px;
			}
			@include xxl-monitor() {font-size: 20px;}
			@include sm-monitor() {font-size: 16px;}
		}
	}
}
#catering-menu1 {
	@include bg-image(url("../img/catering/catering1-1.jpg") center center no-repeat, cover);
}
#catering-menu2 {
	@include bg-image(url("../img/catering/catering1-2.jpg") center center no-repeat, cover);
}
#catering-menu3 {
	@include bg-image(url("../img/catering/catering1-3.jpg") center center no-repeat, cover);
}

/* ================================
Catering 
=================================== */
#cateringplan-sc1-list {
	@include bg-image(url("../img/catering/catering-bg.jpg") center center no-repeat, cover);
}
#cateringplan-sc1-list .wrap {
	width: calc(100% / 5);
	padding: 50px 15px;
	text-align: center;
	position: relative;
	@include lg-monitor() {width: 50%;}
	@include md-monitor() {width: 100%;}
	&:nth-child(odd) {background-color: rgba(4, 4, 10, 0.5);}
	&:nth-child(even) {background-color: rgba(0,0,0,0.7);}
	&:nth-child(3) {
		@include lg-monitor() {background-color: rgba(0,0,0,0.7);}
		@include md-monitor() {background-color: rgba(0,0,0,0.5);}
	}
	&:nth-child(4) {
		@include lg-monitor() {background-color: rgba(4, 4, 10, 0.5);}
		@include md-monitor() {background-color: rgba(4, 4, 10, 0.7);}
	}
	&:last-child {
		@include lg-monitor() {
			width: 100%;
			background-color: rgba(0,0,0,0.8);
		}
		@include md-monitor() {background-color: rgba(0,0,0,0.5);}
	}
	&__title {
		color: $white;
		font: {
			family: $primary-en;
			size: 24px;
			weight: $s-bold;
		}
	}
	&__price {
		color: $white;
		font-weight: $s-bold;
		margin-bottom: 30px;
	}
	ul {
		li {color: $white;}
	}
}
#platter-nav {
	ul {
		li {
			padding: 0 25px;
			margin: 5px 0;
			border-right: 1px solid $d-black;
			&:last-child {border-right: 0;}
			a {
				font: {
					size: 22px;
					weight: $s-bold;
				}
				@include xxl-monitor() {font-size: 18px;}
				@include sm-monitor() {font-size: 16px;}
				&[aria-current="page"] {color: #dc3545;}
			}
		}
	}
}
#platter-sc1 .wrap {
	&__title {
		background-color: $d-black;
		font-family: $second-en;
		color: $white;
		padding: 5px 25px;
		text-transform: uppercase;
	}
	&__table {
		td {
			width: calc(100% / 3);
			@include md-monitor() {width: 100%;}
			label {width: calc(100% - 35px);}
		}
	}
}

/* ================================
Pickup
=================================== */ 
#pickup-sc1 .wrap {
	&__title {
		background-color: $d-black;
		color: $white;
		padding: 5px 25px;
		text-transform: uppercase;
	}
	&__thumb {
		width: 100%;
		height: 100%;
		object-fit: cover;
		@include sm-monitor() {
			height: auto;
			aspect-ratio: 5 / 3;
		}
	}
	&__price {
		font: {
			size: 28px;
			weight: $s-bold;
		}
		@include sm-monitor() {font-size: 24px;}
		span {
			font-size: 16px;
			font-weight: $s-bold;
			display: block;
			@include xxl-monitor() {font-size: 14px;}
		}
	}
	&__title-sm {
		text-transform: uppercase;
		font-size: 30px;
		@include xxl-monitor() {font-size: 24px;}
	}
	&__qty {
		display: flex;
		align-items: center;
		margin-bottom: 10px;
		&:last-child {margin-bottom: 0;}
		&__label {margin-right: 15px;}
	}
	&--platter {
		&__title {
			font: {
				family: $primary-en;
				size: 22px;
				weight: $s-bold;
			}
			span {
				display: block;
				font: {
					size: 1rem;
					weight: $s-bold;
				}
			}
		}
		.wrap__qty__label {width: 115px;}
	}
}